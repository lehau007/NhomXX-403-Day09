# Day 09 Lab - Environment Variables
# Copy this file to .env and fill in real values.
#   cp .env.example .env

# --- API keys for the 3 providers from techstack.md / guidelines.md ---

# OpenAI
OPENAI_API_KEY=sk-...your-key-here...

# Google Gemini
GOOGLE_API_KEY=AI...your-key-here...

# Groq
GROQ_API_KEY=gsk_...your-key-here...

# --- Role-specific provider/model config ---
# Supervisor: reasoning and routing
SUPERVISOR_PROVIDER=openai
SUPERVISOR_MODEL=gpt-4o-mini

# Synthesis: fast answer generation
SYNTHESIS_PROVIDER=groq
SYNTHESIS_MODEL=llama3-8b-8192

# Retrieval: embeddings / retrieval helper
RETRIEVAL_PROVIDER=google
RETRIEVAL_MODEL=gemini-embedding-2-preview

# Policy: lightweight policy analysis
POLICY_PROVIDER=google
POLICY_MODEL=gemini-3.1-flash-lite

# --- ChromaDB config ---
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day09_docs

# --- Retrieval config ---
RETRIEVAL_TOP_K=3

# --- MCP config (Sprint 3 - optional) ---
# MCP_SERVER_URL=http://localhost:8080
# MCP_SERVER_MODE=mock

# --- Trace config ---
TRACE_OUTPUT_DIR=./artifacts/traces
